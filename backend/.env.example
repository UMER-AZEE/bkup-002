SECRET_KEY=replace-with-a-long-random-secret
ENVIRONMENT=development
ACCESS_TOKEN_EXPIRE_MINUTES=60
INVITATION_EXPIRE_HOURS=72
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_MAX_ATTEMPTS=5
PASSWORD_RESET_CODE_EXPIRE_MINUTES=10
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_MAX_ATTEMPTS=5
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_APP_URL=http://localhost:5173
DATABASE_MODE=auto

# MongoDB Atlas connection. If your password contains `@`, keep it URL-encoded as `%40`.
MONGODB_URL=mongodb+srv://username:password%40123@cluster0.example.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=centurion

# Gmail SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME=Sentinel AI
SMTP_USE_TLS=true
SMTP_USE_SSL=false
